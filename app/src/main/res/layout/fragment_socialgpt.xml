<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.socialgpt.SocialGptFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/text_socialgpt_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="@string/socialgpt_title"
            android:textAppearance="@style/TextAppearance.AppCompat.Title"
            android:textSize="28sp" />

        <Button
            android:id="@+id/button_open_settings"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:minHeight="0dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="@string/socialgpt_open_settings" />

        <Button
            android:id="@+id/button_start_bubble"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:minHeight="0dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="@string/socialgpt_start_bubble" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layout_context"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/socialgpt_context_label"
            app:helperText="@string/socialgpt_context_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_context"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:maxLines="6"
                android:minLines="3" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layout_prompt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/socialgpt_prompt_label"
            app:helperText="@string/socialgpt_prompt_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_prompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:imeOptions="actionDone"
                android:inputType="textMultiLine"
                android:maxLines="4"
                android:minLines="2" />
        </com.google.android.material.textfield.TextInputLayout>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_read_after_generate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/socialgpt_enable_screenreader" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/button_generate_draft"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="0dp"
                android:paddingTop="9dp"
                android:paddingBottom="9dp"
                android:text="@string/socialgpt_generate" />

            <ProgressBar
                android:id="@+id/progress_generating"
                style="@android:style/Widget.ProgressBar.Small"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="12dp"
                android:visibility="gone"
                tools:visibility="visible" />
        </FrameLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layout_verify_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/socialgpt_verify_details_label"
            app:helperText="@string/socialgpt_verify_details_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_verify_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:imeOptions="actionDone"
                android:inputType="textMultiLine"
                android:maxLines="3"
                android:minLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp">

            <Button
                android:id="@+id/button_verify_fact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="0dp"
                android:paddingTop="9dp"
                android:paddingBottom="9dp"
                android:text="@string/socialgpt_verify_fact" />

            <ProgressBar
                android:id="@+id/progress_verifying"
                style="@android:style/Widget.ProgressBar.Small"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="12dp"
                android:visibility="gone"
                tools:visibility="visible" />
        </FrameLayout>

        <Button
            android:id="@+id/button_read_aloud"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:enabled="false"
            android:minHeight="0dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="@string/socialgpt_read_aloud" />

        <TextView
            android:id="@+id/text_suggestions_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/socialgpt_suggestions_label"
            android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
            android:visibility="gone"
            tools:visibility="visible" />

        <LinearLayout
            android:id="@+id/layout_suggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layout_modify"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/socialgpt_modify_label"
            android:visibility="gone"
            app:helperText="@string/socialgpt_modify_hint"
            tools:visibility="visible">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_modify"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:imeOptions="actionDone"
                android:inputType="textMultiLine"
                android:maxLines="3"
                android:minLines="2" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/button_apply_modify"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/socialgpt_apply_modify"
            android:visibility="gone"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/text_response_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@android:color/holo_red_dark"
            android:visibility="gone"
            tools:text="Validation error" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/text_response_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/socialgpt_response_label"
                android:textAppearance="@style/TextAppearance.AppCompat.Subhead" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_web_search_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/socialgpt_web_search_used"
                android:visibility="gone"
                app:chipBackgroundColor="@android:color/holo_blue_dark"
                app:chipStrokeColor="@android:color/holo_blue_light"
                app:chipStrokeWidth="1dp"
                app:closeIconVisible="false"
                tools:visibility="visible" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_verify_fact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:cardBackgroundColor="#1D2433"
            app:cardCornerRadius="12dp"
            app:strokeColor="#32415C"
            app:strokeWidth="1dp"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/socialgpt_verify_box_title"
                    android:textAppearance="@style/TextAppearance.AppCompat.Medium"
                    android:textColor="#CFE2FF" />

                <TextView
                    android:id="@+id/text_verify_fact_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:accessibilityLiveRegion="polite"
                    android:autoLink="web"
                    android:linksClickable="true"
                    android:text="@string/socialgpt_verify_box_placeholder"
                    android:textColor="#F1F4FF"
                    android:textIsSelectable="true"
                    tools:text="Fact-check response" />

                <TextView
                    android:id="@+id/text_verify_followup_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/socialgpt_additional_questions"
                    android:textAppearance="@style/TextAppearance.AppCompat.Medium"
                    android:textColor="#CFE2FF" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layout_verify_followup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:hint="@string/socialgpt_followup_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/input_verify_followup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:imeOptions="actionDone"
                        android:inputType="textMultiLine"
                        android:maxLines="3"
                        android:minLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/button_verify_followup"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/socialgpt_ask_followup" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/text_response_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:accessibilityLiveRegion="polite"
            android:autoLink="web"
            android:linksClickable="true"
            android:text="@string/socialgpt_response_placeholder"
            android:textIsSelectable="true"
            android:textSize="16sp" />
    </LinearLayout>
</ScrollView>

