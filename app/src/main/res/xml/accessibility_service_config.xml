<?xml version="1.0" encoding="utf-8"?>
<!--
    Permissions explained:
    - canRetrieveWindowContent="true"  → lets the service read ALL visible text on screen
    - accessibilityEventTypes          → we listen for window changes and content changes
    - android:settingsActivity         → users are sent here from Android Accessibility settings
    No internet permission is used by the service itself; captured text is only stored locally
    and sent to the app via broadcast when the user explicitly taps "Capture".
-->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged|typeWindowContentChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagDefault|flagRequestAccessibilityButton"
    android:canRetrieveWindowContent="true"
    android:description="@string/accessibility_service_description"
    android:notificationTimeout="100" />

